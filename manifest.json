{
  "manifest_version": 3,
  "name": "Tripwire",
  "version": "1.0",
  "description": "Detects manipulative UX patterns in real time.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
